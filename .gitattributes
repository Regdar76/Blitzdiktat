# Zeilenenden normalisieren; plattformkritische Skripte festnageln
* text=auto
# Unix-Skripte brauchen LF (macOS-CI, Gradle-Wrapper auf Linux)
*.sh text eol=lf
gradlew text eol=lf
# Windows-Batch braucht CRLF
*.bat text eol=crlf
# Binärdateien
*.png binary
*.icns binary
*.jar binary
*.ico binary
BlitzdiktatWin/Blitzdiktat-Windows-Setup-2.1.4.exe filter=lfs diff=lfs merge=lfs -text
BlitzdiktatAndroid/Blitzdiktat-Android-0.3.1.apk filter=lfs diff=lfs merge=lfs -text
