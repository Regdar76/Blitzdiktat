# Zeilenenden normalisieren; plattformkritische Skripte festnageln
* text=auto
# Unix-Skripte brauchen LF (macOS-CI, Gradle-Wrapper auf Linux)
*.sh text eol=lf
gradlew text eol=lf
# Windows-Batch braucht CRLF
*.bat text eol=crlf
# Binärdateien
*.png binary
*.icns binary
*.jar binary
*.ico binary
BlitzdiktatWin/Blitzdiktat-Windows-Setup-*.exe filter=lfs diff=lfs merge=lfs -text
BlitzdiktatAndroid/Blitzdiktat-Android-*.apk filter=lfs diff=lfs merge=lfs -text
